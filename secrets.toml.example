# Copy this file to .streamlit/secrets.toml and fill in your real values.
# Never commit the real secrets.toml to GitHub - keep .streamlit/secrets.toml
# in your .gitignore. On Streamlit Community Cloud, paste this content into
# the app's "Secrets" settings panel instead of committing a file.

sheet_url = "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit"

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
